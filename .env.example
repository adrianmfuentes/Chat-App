# Used by docker-compose when running `docker compose up` from the repo root.
# For running the frontend or backend directly (without Docker), use their
# own .env files instead: frontend/.env.example and server/.env.example.

JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=24h
CORS_ORIGIN=http://localhost:3000
REACT_APP_BACKEND_URL=http://localhost:4000
